{
  "name": "shared",
  "type": "module",
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "generate:watch": "tsx watch scripts/generate.ts",
    "tsc": "tsc --noEmit --watch",
    "prettier": "prettier . --write --config .prettierrc.json",
    "eslint": "eslint . --fix",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "axios": "1.8.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config": "workspace:*",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-config": "workspace:*",
    "tsconfig": "workspace:*",
    "tsx": "4.20.3",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier . --write"
    ]
  }
}
