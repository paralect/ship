{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build:types": {
      "dependsOn": ["^build:types"],
      "outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"]
    },
    "build": {
      "dependsOn": ["^build", "^build:types"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "api#migrate-dev": {
      "cache": false
    },
    "api#schedule-dev": {
      "dependsOn": ["api#migrate-dev"],
      "cache": false,
      "persistent": true
    },
    "precommit": {
      "outputs": []
    },
    "test:eslint": {
      "outputs": []
    }
  }
}
