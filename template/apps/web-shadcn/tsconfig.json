{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "baseUrl": "src",
    "rootDir": ".",
    "paths": {
      "@/*": ["./*"],
      "public/*": ["../public/*"],
      "types": ["./types.ts"],
      "config": ["./config/index.ts"],
      "routes": ["./routes.ts"],
      "services": ["./services/index.ts"],
      "utils": ["./utils/index.ts"],
      "query-client": ["./query-client.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.json",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "next.config.mjs",
    "postcss.config.mjs"
  ]
}
