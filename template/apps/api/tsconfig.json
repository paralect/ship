{
  "extends": "tsconfig/nodejs.json",
  "compilerOptions": {
    "jsx": "react", // for using Mailer
    "rootDir": ".",
    "outDir": "dist",
     "paths": {
      "*": ["./src/*"],
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["**/*.ts", "**/*.json"]
}
