{
  "name": "api",
  "type": "module",
  "version": "1.0.0",
  "description": "Hono + oRPC API",
  "author": "Paralect",
  "license": "MIT",
  "main": "./src/router.ts",
  "types": "./dist/router.d.ts",
  "scripts": {
    "build": "tsc",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "NODE_ENV=development APP_ENV=development tsx watch --env-file=.env src/app.ts",
    "start": "NODE_ENV=development APP_ENV=development tsx --env-file=.env src/app.ts",
    "migrate-dev": "NODE_ENV=development APP_ENV=development tsx --env-file=.env src/migrator.ts",
    "migrate": "tsx src/migrator.ts",
    "schedule-dev": "NODE_ENV=development APP_ENV=development tsx watch --env-file=.env src/scheduler.ts",
    "schedule": "tsx src/scheduler.ts",
    "tsc": "tsc --noEmit --watch",
    "prettier": "prettier . --write --config .prettierrc.json",
    "eslint": "eslint . --fix",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.828.0",
    "@aws-sdk/lib-storage": "3.828.0",
    "@aws-sdk/s3-request-presigner": "3.828.0",
    "@hono/node-server": "^1.13.0",
    "@node-rs/argon2": "2.0.2",
    "@orpc/openapi": "1.13.9",
    "@orpc/server": "^1.5.0",
    "@oslojs/crypto": "1.0.1",
    "@oslojs/encoding": "1.1.0",
    "@paralect/node-mongo": "3.3.0",
    "@socket.io/redis-adapter": "8.3.0",
    "@socket.io/redis-emitter": "5.1.0",
    "app-constants": "workspace:*",
    "arctic": "3.7.0",
    "dayjs": "1.11.13",
    "hono": "^4.7.0",
    "ioredis": "5.6.1",
    "lodash": "4.17.21",
    "mailer": "workspace:*",
    "mixpanel": "0.18.1",
    "node-schedule": "2.1.1",
    "resend": "4.5.2",
    "socket.io": "4.8.1",
    "tldts": "7.0.8",
    "winston": "3.17.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/lodash": "4.17.17",
    "@types/node": "catalog:",
    "@types/node-schedule": "2.1.7",
    "eslint": "catalog:",
    "eslint-config": "workspace:*",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-config": "workspace:*",
    "tsconfig": "workspace:*",
    "tsx": "4.20.4",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.ts": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
