    "dayjs": "1.11.10",
    "dompurify": "3.2.6",
    "dotenv-flow": "4.1.0",
    "framer-motion": "12.35.0",
    "lodash": "4.17.21",
    "lucide-react": "^0.460.0",
    "mixpanel-browser": "2.53.0",
    "motion": "12.35.0",
    "next": "15.5.9",
    "next-themes": "0.4.6",
    "object-to-formdata": "4.5.1",
    "radix-ui": "1.4.3",
    "react": "catalog:",
    "react-day-picker": "9.13.2",
    "react-dom": "catalog:",
    "react-dropzone": "15.0.0",
    "react-hook-form": "7.57.0",
    "react-icons": "5.6.0",
    "shared": "workspace:*",
    "socket.io-client": "4.7.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.0",
