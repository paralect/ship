  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query-devtools": "5.50.1",
    "@types/lodash": "4.17.6",
    "@types/mixpanel-browser": "2.49.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "19.0.4",
    "eslint": "catalog:",
    "eslint-config": "workspace:*",
    "lint-staged": "15.5.2",
    "prettier": "catalog:",
    "prettier-config": "workspace:*",
    "tailwindcss": "^4.0.0",
    "tsconfig": "workspace:*",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.css": [
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier . --write"
