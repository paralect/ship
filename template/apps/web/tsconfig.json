{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "baseUrl": "src",
    "rootDir": ".",
    "paths": {
      "@/*": ["./*"],
      "public/*": ["../public/*"],
      "content-collections": ["../.content-collections/generated"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.json",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "next.config.mjs",
    "postcss.config.json"
  ]
}
