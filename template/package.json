{
  "name": "ship",
  "scripts": {
    "admin:set": "pnpm --filter api admin:set",
    "infra": "bash ./bin/start.sh postgres redis",
    "turbo-start": "turbo run development",
    "docker": "bash ./bin/start.sh",
    "start": "bash ./bin/run-all.sh",
    "plugin:install": "tsx scripts/plugin.ts install",
    "plugin:uninstall": "tsx scripts/plugin.ts uninstall",
    "plugin:list": "tsx scripts/plugin.ts list",
    "plugin:dev": "tsx scripts/plugin.ts dev",
    "prepare": "cd .. && husky template/.husky"
  },
  "devDependencies": {
    "husky": "9.0.11",
    "turbo": "2.5.4",
    "tsx": "4.20.4"
  },
  "optionalDependencies": {
    "turbo-darwin-64": "2.5.4",
    "turbo-darwin-arm64": "2.5.4",
    "turbo-linux-64": "2.5.4",
    "turbo-linux-arm64": "2.5.4",
    "turbo-windows-64": "2.5.4",
    "turbo-windows-arm64": "2.5.4"
  },
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">= 22.13.0",
    "yarn": "please-use-pnpm",
    "pnpm": ">= 9.5.0"
  }
}
