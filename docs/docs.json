{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ship",
  "colors": {
    "primary": "#9166A9",
    "light": "#ECCBFF",
    "dark": "#9166A9"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "anchors": [
      {
        "anchor": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "contribution-guide", "llms"]
          },
          {
            "group": "Ship Components",
            "pages": [
              "architecture",
              {
                "group": "API",
                "pages": [
                  "api-reference/overview",
                  {
                    "group": "Routing",
                    "pages": [
                      "api-reference/routing/overview",
                      "api-reference/routing/middlewares"
                    ]
                  },
                  "api-reference/api-limitations",
                  "api-reference/using-events",
                  "api-reference/data-service",
                  "api-reference/api-action",
                  "api-reference/api-action-validator",
                  "api-reference/event-handler",
                  "api-reference/events",
                  "api-reference/middlewares",
                  "api-reference/testing",
                  "api-reference/workflow"
                ]
              },
              {
                "group": "Package sharing",
                "pages": ["package-sharing/overview", "package-sharing/schemas"]
              },
              "migrator",
              "scheduler",
              "mailer",
              "github-actions",
              "git-hooks",
              {
                "group": "Web",
                "pages": [
                  "web/overview",
                  "web/styling",
                  "web/routing",
                  "web/calling-api",
                  "web/forms",
                  "web/services",
                  "web/environment-variables",
                  "web/storybook"
                ]
              },
              {
                "group": "Deployment",
                "pages": [
                  "deployment/digital-ocean-apps",
                  "deployment/digital-ocean-apps-iac",
                  "deployment/render",
                  {
                    "group": "Kubernetes",
                    "pages": [
                      "deployment/kubernetes/overview",
                      "deployment/kubernetes/digital-ocean",
                      "deployment/kubernetes/aws"
                    ]
                  }
                ]
              },
              "retool"
            ]
          },
          {
            "group": "Packages",
            "pages": [
              {
                "group": "node-mongo",
                "pages": [
                  "packages/node-mongo/overview",
                  "packages/node-mongo/changelog",
                  {
                    "group": "API Reference",
                    "pages": [
                      "packages/node-mongo/api-reference/service",
                      "packages/node-mongo/api-reference/events",
                      "packages/node-mongo/api-reference/transactions"
                    ]
                  }
                ]
              },
              "packages/create-ship-app"
            ]
          },
          {
            "group": "Plugins",
            "pages": [
              "plugins/overview",
              "plugins/stripe-subscriptions",
              "plugins/ai-chat"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Twitter",
          "href": "https://twitter.com/paralect_ship",
          "icon": "twitter"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/zNWEatRWqx",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": "/logo.png",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "navbar": {
    "links": [
      {
        "label": "What's Ship?",
        "href": "https://ship.paralect.com/#product-platform"
      },
      {
        "label": "Showcase",
        "href": "https://ship.paralect.com/#showcase"
      },
      {
        "label": "Contributors",
        "href": "https://ship.paralect.com/#contributors"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/paralect/ship"
    }
  },
  "footer": {
    "socials": {
      "twitter": "https://twitter.com/paralect_ship",
      "github": "https://github.com/paralect/ship"
    }
  }
}
